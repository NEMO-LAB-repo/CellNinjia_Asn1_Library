    unknown2                    (2),
    unknown3                    (3),
    unknown4                    (4),
    qam-16                      (5),
    unknown6                    (6),
    unknown7                    (7),
    unknown8                    (8),
    qam-64                      (9),
    unknown10                   (10),
    unknown11                   (11),
    qam-256                     (12),
    unknown13                   (13),
    unknown14                   (14),
    unknown15                   (15)
}

