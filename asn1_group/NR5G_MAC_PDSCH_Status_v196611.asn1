NR5G-MAC-PDSCH-Status-v196611 DEFINITIONS ::=BEGIN

-- S-H --
NR5G-MAC-PDSCH-Status-v196611-S-H ::=SEQUENCE
{
    version                     INTEGER(0..4294967295),
    skip                        OCTET STRING(SIZE(3)),
    num-records                 INTEGER(0..255)
}

--R-H -
NR5G-MAC-PDSCH-Status-v196611-R-H ::=SEQUENCE
{
    slot                  INTEGER(0..255),
    skip1                 BIT STRING(SIZE(5)),
    numerology            Numerology,

    skip3                 BIT STRING(SIZE(6)),
    frame                 INTEGER(0..1023),
    num-pdsch               INTEGER(0..255), 
    skip2                 OCTET STRING(SIZE(3))
}
Numerology ::=ENUMERATED
{
    n-15khz                    (0),        
    n-30khz                       (1),
    n-60khz                    (2),
    n-120khz                   (3),
    n-240khz                   (4),
    n-480khz                   (5),
    n-960khz                   (6)
}

-- PDSCH Status Info --
NR5G-MAC-PDSCH-Status-Info-v196611 ::=SEQUENCE
{
    skip1                 BIT STRING(SIZE(9)),

    slot-number      INTEGER(0..31),
    sfn              INTEGER(0..1023),

    skip2                 BIT STRING(SIZE(3)),
    bandwidth       INTEGER(0..15),
    skip13                BIT STRING(SIZE(1)),

    erfcn            INTEGER(0..4194303),
    physicall-cell-id   INTEGER(0..1023),

    skip3                 BIT STRING(SIZE(2)),
    tbsize            INTEGER(0..131071),
    skip4                 BIT STRING(SIZE(6)),
    mcs               INTEGER(0..31),
    skip5                BIT STRING(SIZE(3)),

    harq-or-mbsfn-area-id   INTEGER(0..15),
    rv                   INTEGER(0..3),
    num-rb               INTEGER(0..511),

    skip6                 BIT STRING(SIZE(1)),
    num-layers-raw      INTEGER(0..3),
    skip11                 BIT STRING(SIZE(3)),
    k1-or-pmch-id       INTEGER(0..15),
    rnti-type           INTEGER(0..15),


    skip7                 BIT STRING(SIZE(5)),
    discard-mode      INTEGER(0..3),
    ndi                 INTEGER(0..1),
    new-tx-flag        INTEGER(0..1),
    crc-status         CRC-Status,
    skip8                 BIT STRING(SIZE(5)),

    num-retx            INTEGER(0..7),

    num-rx              Num-RX,
    skip9                 BIT STRING(SIZE(2)),
    mod-type            Mod-Type,

    skip10              OCTET STRING(SIZE(1))
}
CRC-Status ::=ENUMERATED
{
    crc-fail                    (0),
    crc-pass                    (1)
}
Num-RX ::=ENUMERATED
{
    unknown0                    (0),
    mimo2x2                         (1),
    unknown2                    (2),
    mimo4x4                       (3)
}
Mod-Type ::=ENUMERATED
{
    unknown0                    (0),
