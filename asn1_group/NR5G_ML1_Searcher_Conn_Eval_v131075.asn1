NR5G-ML1-Searcher-Conn-Eval-v131075 DEFINITIONS ::= BEGIN

NR5G-ML1-Searcher-Conn-Eval-v131075-S-H ::= SEQUENCE 
{
    version      INTEGER(0..4294967295),
    skip0        BIT STRING(SIZE(11)),
    system-frame-number INTEGER(0..1023),
    subframe-number INTEGER(0..15),
    slot-number  INTEGER(0..31),
    skip1        BIT STRING(SIZE(2)),

    num-cells         INTEGER(0..255),
    skip2        OCTET STRING(SIZE(3))
}

NR5G-ML1-Searcher-Conn-Eval-v131075-Cell-Info ::= SEQUENCE
{
    skip0         BIT STRING(SIZE(14)),
